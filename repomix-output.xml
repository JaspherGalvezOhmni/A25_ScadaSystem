/* --- GLOBAL STYLES & DARK THEME --- */
:root {
  /* Colors */
  --bg-dark: #1e1e1e;
  --bg-sidebar: #2d2d2d;
  --bg-header: #2d2d2d;
  --text-main: #dcdcdc;
  --text-dim: #a0a0a0;
  --accent-blue: #41D1FF;

  /* Status Colors */
  --color-healthy: #2ecc71;
  --color-fault: #e74c3c;
  --color-unknown: #7f8c8d;
  --color-warning: #f39c12;

  /* Borders & Spacing */
  --border: 1px solid #444;
  --radius: 8px;
}

body {
  margin: 0;
}

.App {
  display: flex;
  flex-direction: column;
  height: 100vh;
  width: 100vw;
  overflow: hidden; /* Prevent the whole body from scrolling */
}

.main-content {
  flex-grow: 1;
  overflow-y: auto;
}

/* Custom Scrollbar for Dark Theme */
::-webkit-scrollbar {
  width: 10px;
  height: 10px;
}

::-webkit-scrollbar-track {
  background: #2d2d2d;
}

::-webkit-scrollbar-thumb {
  background: #555;
  border-radius: 5px;
}

::-webkit-scrollbar-thumb:hover {
  background: #777;
}

/* --- HEADER & NAVIGATION --- */
.App-header {
  display: flex;
  align-items: center;
  background-color: #2d2d2d;
  padding: 0 2rem;
  height: 60px;
  border-bottom: 1px solid #444;
  flex-shrink: 0;
}

.logo-container img {
