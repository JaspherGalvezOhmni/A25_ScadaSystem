  display: flex;
  justify-content: center;
  gap: 1rem;
}

.navigation a {
  color: #a0a0a0;
  text-decoration: none;
  font-size: 1.1em;
  padding: 0.5rem 1rem;
  border-radius: 6px;
  transition: background-color 0.2s;
}

.navigation a.active,
.navigation a:hover {
