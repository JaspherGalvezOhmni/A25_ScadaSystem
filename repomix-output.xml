  background-color: #444;
}

.header-right-side {
  display: flex;
  align-items: center;
  gap: 1.5rem;
  margin-left: auto;
}

.status-time {
  color: #a0a0a0;
  white-space: nowrap;
  font-variant-numeric: tabular-nums;
}

.logout-button {
  background-color: #3a3a3a;
  color: #a0a0a0;
  border: 1px solid #555;
  border-radius: 6px;
  padding: 0.5rem 1rem;
  font-size: 1em;
  cursor: pointer;
  transition: all 0.2s;
}

.logout-button:hover {
  background-color: #c0392b;
  color: white;
  border-color: #e74c3c;
}

/* --- GENERIC COMPONENTS --- */
.sidebar {
  background-color: #2d2d2d;
  overflow-y: auto; /* ENABLE VERTICAL SCROLLING */
  height: 100%;    /* Fill the height of the grid row */
  display: flex;
  flex-direction: column;
  padding-bottom: 20px; /* Give some breathing room at the bottom */
}

/* Custom scrollbar for sidebars so they look "Industrial" and slim */
.sidebar::-webkit-scrollbar {
  width: 6px;
}
.sidebar::-webkit-scrollbar-track {
  background: #1a1a1a;
}
.sidebar::-webkit-scrollbar-thumb {
  background: #444;
  border-radius: 3px;
}
.sidebar::-webkit-scrollbar-thumb:hover {
  background: #41D1FF;
}


.card {
  background-color: #2d2d2d;
  border-radius: 8px;
  padding: 1.5rem;
}

/* --- HOME PAGE --- */
.home-layout {
  display: grid;
  grid-template-columns: 300px 1fr 350px;
  /* Subtract the header (60px) and the divider (6px) */
  height: calc(100vh - 66px); 
  width: 100%;
  overflow: hidden; /* Grid itself doesn't scroll; the children do */
}

.commands-sidebar {
  padding: 2rem;
  display: flex;
  flex-direction: column;
  gap: 1.5rem;
}

.commands-sidebar h2 {
  margin: 0 0 1rem 0;
  font-size: 1.5em;
  font-weight: 600;
  border-bottom: 1px solid #444;
  padding-bottom: 1rem;
}

.commands-sidebar button {
  width: 100%;
  padding: 1.2rem;
  font-size: 1.5em;
  border-radius: 8px;
  border: 1px solid #555;
  background-color: #3a3a3a;
  color: #dcdcdc;
  cursor: pointer;
  transition: background-color 0.2s;
}

.commands-sidebar button:hover {
  background-color: #4a4a4a;
}

.commands-sidebar button:disabled {
  background-color: #2a2a2a;
  color: #666;
  cursor: not-allowed;
  border-color: #444;
}

.status-sidebar {
  padding: 1rem 2rem 2rem 2rem;
  display: flex;
  flex-direction: column;
  gap: 1.5rem;
}

/* --- UNIVERSAL INDUSTRIAL SIDEBAR STYLES --- */
.sidebar.status-sidebar {
  padding: 15px 15px 40px 15px !important; /* Added 40px bottom padding */
  box-sizing: border-box;
}

/* Reusing the look of the Command boxes for Status boxes */
.status-box {
  border: 1px solid #333;
  background-color: #252525;
  border-radius: 8px;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  box-shadow: 0 4px 6px rgba(0, 0, 0, 0.3);
  box-sizing: border-box;
}

.status-box-header {
  background-color: #f0f0f0; /* Same as Engineering Command headers */
  color: #1e1e1e;
  text-align: center;
  font-weight: bold;
  font-size: 0.85rem;
  padding: 10px;
  text-transform: uppercase;
  letter-spacing: 1px;
}

.status-box-row {
  display: flex;
  margin: 0 10px 10px 10px;
  border: 1px solid #444;
  border-radius: 4px;
  background: #1e1e1e; /* Matches Flywheel Visual Background */
